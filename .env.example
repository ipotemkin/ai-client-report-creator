# Скопируйте в .env и подставьте значения:
#   cp .env.example .env

# Обязательно: ключ OpenAI-совместимого API (ProxyAPI и др.)
PROXYAPI_API_KEY=

# Необязательно: базовый URL (по умолчанию — ProxyAPI)
# PROXYAPI_OPENAI_BASE_URL=https://api.proxyapi.ru/openai/v1

# Необязательно: модель для текста (отчёт, карточка — копирайт)
# OPENAI_MODEL=gpt-4o-mini

# Необязательно: модель для фона карточки (main.py card)
# OPENAI_IMAGE_MODEL=gpt-image-1
